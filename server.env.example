# Copy this file into your server .env and fill only the secrets you actually use.

# -------------------------------------------------------------------
# Common
# -------------------------------------------------------------------
NODE_ENV=development
APP_ENV=local
EXCHANGE_CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-secret

# -------------------------------------------------------------------
# Upbit
# Docs:
# - https://docs.upbit.com/kr/reference/auth
# - https://docs.upbit.com/kr/reference
# -------------------------------------------------------------------
UPBIT_API_BASE_URL=https://api.upbit.com
UPBIT_PUBLIC_WS_URL=wss://api.upbit.com/websocket/v1
UPBIT_PRIVATE_WS_URL=wss://api.upbit.com/websocket/v1/private
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# -------------------------------------------------------------------
# Bithumb
# Docs:
# - https://apidocs.bithumb.com/docs/%EB%B9%A0%EB%A5%B8-%EC%8B%9C%EC%9E%91-%EA%B0%80%EC%9D%B4%EB%93%9C
# - https://apidocs.bithumb.com/docs/%EC%9D%B8%EC%A6%9D-%ED%97%A4%EB%8D%94-%EB%A7%8C%EB%93%A4%EA%B8%B0
# - https://apidocs.bithumb.com/reference/%ED%85%8C%EC%8A%A4%ED%8A%B8-%EB%B0%8F-%EC%9A%94%EC%B2%AD-%EC%98%88%EC%A0%9C.md
# -------------------------------------------------------------------
BITHUMB_API_BASE_URL=https://api.bithumb.com
BITHUMB_WS_URL=wss://ws-api.bithumb.com/websocket/v1
BITHUMB_ACCESS_KEY=
BITHUMB_SECRET_KEY=

# -------------------------------------------------------------------
# Coinone
# Docs:
# - https://docs.coinone.co.kr/v1.1/docs/about-public-api
# - https://docs.coinone.co.kr/reference/public-websocket-1
# - https://docs.coinone.co.kr/reference/private-websocket-1
# -------------------------------------------------------------------
COINONE_API_BASE_URL=https://api.coinone.co.kr
COINONE_PUBLIC_WS_URL=wss://stream.coinone.co.kr
COINONE_PRIVATE_WS_URL=wss://stream.coinone.co.kr/v1/private
COINONE_ACCESS_TOKEN=
COINONE_SECRET_KEY=

# -------------------------------------------------------------------
# Korbit
# Docs:
# - https://docs.korbit.co.kr
# -------------------------------------------------------------------
KORBIT_API_BASE_URL=https://api.korbit.co.kr
KORBIT_PUBLIC_WS_URL=wss://ws-api.korbit.co.kr/v2/public
KORBIT_PRIVATE_WS_URL=wss://ws-api.korbit.co.kr/v2/private
KORBIT_API_KEY=
KORBIT_SECRET_KEY=
KORBIT_SIGNING_MODE=hmac_sha256

# -------------------------------------------------------------------
# Binance (Kimchi premium reference price)
# Public price source only. API key is optional unless your server uses
# higher-rate or private endpoints.
# Docs:
# - https://developers.binance.com/docs/binance-spot-api-docs/rest-api
# -------------------------------------------------------------------
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/ws
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# -------------------------------------------------------------------
# FX / exchange rate provider for KRW conversion in Kimchi tab
# Use one provider consistently and cache it server-side.
# -------------------------------------------------------------------
FX_API_BASE_URL=https://api.exchangerate.host
FX_API_KEY=

# -------------------------------------------------------------------
# Recommended server-side feature toggles
# -------------------------------------------------------------------
ENABLE_UPBIT=1
ENABLE_BITHUMB=1
ENABLE_COINONE=1
ENABLE_KORBIT=1
ENABLE_BINANCE_REFERENCE=1
